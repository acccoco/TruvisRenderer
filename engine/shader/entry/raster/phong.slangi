#pragma once

/// raster Phong pass 在 VS/PS 之间传递的插值属性。
///
/// world_pos 和 frag_normal 由 vertex shader 明确写入，fragment shader 只做归一化和光照；
/// 这样 sample raster path 不需要访问 runtime scene 的 vertex buffer。
struct CoarseVertex
{
    [[vk::location(0)]]
    float3 world_pos : WORLD_POS;

    [[vk::location(1)]]
    float3 frag_normal : FRAG_NORMAL;

    [[vk::location(2)]]
    float2 uv : UV;
};
